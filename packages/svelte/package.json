{
	"name": "@haptics/svelte",
	"version": "1.0.0",
	"description": "Svelte actions and imperative API for haptic feedback. iOS Safari and Android Vibration API.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": ["dist"],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"type-check": "tsc --noEmit",
		"test": "vitest run"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/howdoiusekeyboard/haptics.git",
		"directory": "packages/svelte"
	},
	"author": "Howdoiusekeyboard",
	"license": "MIT",
	"keywords": [
		"haptics",
		"svelte",
		"haptic-feedback",
		"vibration",
		"ios",
		"android",
		"action"
	],
	"dependencies": {
		"@haptics/core": "workspace:*"
	},
	"peerDependencies": {
		"svelte": ">=4"
	},
	"devDependencies": {
		"jsdom": "^29.0.0",
		"tsup": "^8.0.0",
		"vitest": "^4.1.0"
	}
}
